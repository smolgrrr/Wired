{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/refresh-feed",
      "schedule": "*/3 * * * *"
    }
  ],
  "images": {
    "sizes": [48, 96, 384, 640, 828, 1080, 1200],
    "domains": [],
    "minimumCacheTTL": 86400,
    "formats": ["image/avif", "image/webp"],
    "qualities": [75],
    "remotePatterns": [
      { "protocol": "https", "hostname": "image.nostr.build" },
      { "protocol": "https", "hostname": "i.nostr.build" },
      { "protocol": "https", "hostname": "cdn.nostr.build" },
      { "protocol": "https", "hostname": "nostr.build" },
      { "protocol": "https", "hostname": "cdn.nostr.band" },
      { "protocol": "https", "hostname": "cdn.nostrcheck.me" },
      { "protocol": "https", "hostname": "blossom.primal.net" },
      { "protocol": "https", "hostname": "profilepics.nostur.com" },
      { "protocol": "https", "hostname": "inner.sebastix.social" },
      { "protocol": "https", "hostname": "blossom-espelhator.girino.org" },
      { "protocol": "https", "hostname": "^(.*\\.)?blossom\\.band$" }
    ]
  },
  "rewrites": [
    {
      "source": "/((?!api/|_vercel/|src/|@|node_modules/|assets/|fonts/|favicon\\.svg|robots\\.txt|noise\\.png).*)",
      "destination": "/index.html"
    }
  ]
}